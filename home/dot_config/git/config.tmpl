[user]
    name = {{ .chezmoi.username }}
    email = {{ .email }}

[github]
    user = {{ .github_user }}

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = true

[core]
    autocrlf = input
    editor = hx

[rerere]
    enabled = true

[submodule]
    recurse = true
